### 9.2 Confidence Scoring

```typescript
function calculateConfidence(parsed: ParsedRepository): number {
  let score = 0;
  
  // Repository type match: +40 points
  if (parsed.metadata.type === "supported") score += 40;
  
  // Dependency extraction success: +30 points
  if (parsed.dependencies.length > 0) score += 30;
  
  // Layer detection success: +20 points
  if (parsed.layers.length >= 3) score += 20;
  
  // Story generation success: +10 points
  if (parsed.storySteps.length > 0) score += 10;
  
  return Math.min(score, 100);
}
```

